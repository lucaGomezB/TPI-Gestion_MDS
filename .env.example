# Database
DATABASE_URL=postgresql+asyncpg://activia:activia@localhost:5432/activia_trace

# Auth (JWT)
SECRET_KEY=change-me-to-a-random-32-char-string
ENCRYPTION_KEY=change-me-to-an-exact-32-char-key
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Moodle (per-tenant, set in runtime config)
MOODLE_WS_URL=
MOODLE_WS_TOKEN=

# N8N
N8N_WEBHOOK_URL=http://n8n:5678/webhook/

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
